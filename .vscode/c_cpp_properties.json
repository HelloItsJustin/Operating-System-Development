{
    "configurations": [
        {
            "name": "Watcom",
            "includePath": [
                "${workspaceFolder}/**"
            ],
            "defines": [
                "_DEBUG",
                "UNICODE",
                "_UNICODE",
                "_cdecl"
            ],
            "compilerPath": "watcom/watcom/binl64/wcc",
            "cStandard": "c99",
            "cppStandard": "gnu++14",
            "intelliSenseMode": "clang-x64",
            "configurationProvider": "ms-vscode.makefile-tools",
            "compilerArgs": [
                "-4 -d3 -s -wx -ms -zl -zq"
            ]
        }
    ],
    "version": 4
}